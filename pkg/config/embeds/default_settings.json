{
  "active_profile": "local",
  "default_template": "gemini",

  // Bucket configuration for cloud storage persistence.
  // Uncomment and configure to enable bucket-based storage.
  // Values can reference environment variables using ${VAR} syntax.
  // "bucket": {
  //   "provider": "${SCION_BUCKET_PROVIDER}",  // Cloud provider: "GCS"
  //   "name": "${SCION_BUCKET_NAME}",          // Bucket name, e.g., "scion-abc12"
  //   "prefix": "${SCION_BUCKET_PREFIX}"       // Prefix within bucket, e.g., "scion"
  // },

  "runtimes": {
    "docker": {
      "host": ""
    },
    "container": {
      "tmux": true
    },
    "kubernetes": {
      "context": "",
      "namespace": ""
    }
  },
  "harnesses": {
    "gemini": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-gemini:latest",
      "user": "node"
    },
    "claude": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-claude:latest",
      "user": "node"
    },
    "opencode": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-opencode:latest",
      "user": "node"
    },
    "codex": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-codex:latest",
      "user": "node"
    }
  },
  "profiles": {
    "local": {
      "runtime": "container",
      "tmux": true
    },
    "remote": {
      "runtime": "kubernetes",
      "tmux": true,
      "harness_overrides": {
      }
    }
  }
}
